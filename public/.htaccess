# Disable directory listing
Options -Indexes

# Enable URL rewriting
RewriteEngine On

# Serve pre-rendered HTML files for Next.js static export routes
# If the exact file exists, serve it directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If the exact directory exists AND has an index.html, serve it
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.+?)/?$ $1/index.html [L]

# Fallback: try appending /index.html to the path
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.+?)/?$ $1/index.html [L]

# Fallback: try appending .html to the path
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Final fallback to index.html (for client-side 404 or root)
RewriteRule ^ /index.html [L]
